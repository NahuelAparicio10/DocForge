<Window x:Class="DocForge.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DocForge"
        Height="920"
        Width="1380"
        MinHeight="760"
        MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="DocForge"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Text="Drop one or many PDFs into the window. Extract text, generate local AI summaries, and export each file automatically next to the original PDF."
                           Margin="0,6,0,14"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>

                <WrapPanel>
                    <Button Content="Add PDFs"
                            Command="{Binding BrowsePdfCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="120"/>

                    <Button Content="Extract All"
                            Command="{Binding ExtractAllCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="120"/>

                    <Button Content="Generate Selected AI Summary"
                            Command="{Binding GenerateSelectedAiSummaryCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="210"
                            IsEnabled="{Binding IsAiSummaryAvailable}"/>

                    <Button Content="Generate All AI Summaries"
                            Command="{Binding GenerateAllAiSummariesCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="195"
                            IsEnabled="{Binding IsAiSummaryAvailable}"/>

                    <Button Content="Clear"
                            Command="{Binding ClearDocumentsCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="100"
                            Margin="0"/>
                </WrapPanel>

                <TextBlock Text="{Binding AiSummaryStatus}"
                           Margin="0,12,0,0"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Loaded PDFs"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding Documents}"
                             SelectedItem="{Binding SelectedDocument}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="0,0,0,8" Style="{StaticResource CardBorderStyle}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding FileName}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Status}"
                                                   Margin="0,4,0,0"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.25*"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding SelectedFileName, StringFormat=Extracted Text - {0}}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <WrapPanel Grid.Row="2">
                            <Button Content="Export Selected TXT"
                                    Command="{Binding ExportSelectedTextTxtCommand}"
                                    Style="{StaticResource SelectedActionButtonStyle}"
                                    Width="150"/>

                            <Button Content="Export Selected DOCX"
                                    Command="{Binding ExportSelectedTextDocxCommand}"
                                    Style="{StaticResource SelectedActionButtonStyle}"
                                    Width="160"/>

                            <Button Content="Export All TXT"
                                    Command="{Binding ExportAllTextTxtCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="130"/>

                            <Button Content="Export All DOCX"
                                    Command="{Binding ExportAllTextDocxCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="140"
                                    Margin="0"/>
                        </WrapPanel>

                        <TextBox Grid.Row="4"
                                 Text="{Binding ExtractedTextPreview, Mode=OneWay}"
                                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding SelectedFileName, StringFormat=AI Summary - {0}}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                        <WrapPanel Grid.Row="2">
                            <Button Content="Export Selected Summary TXT"
                                    Command="{Binding ExportSelectedAiSummaryTxtCommand}"
                                    Style="{StaticResource SelectedActionButtonStyle}"
                                    Width="190"/>

                            <Button Content="Export Selected Summary DOCX"
                                    Command="{Binding ExportSelectedAiSummaryDocxCommand}"
                                    Style="{StaticResource SelectedActionButtonStyle}"
                                    Width="200"/>

                            <Button Content="Export All Summary TXT"
                                    Command="{Binding ExportAllAiSummaryTxtCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="180"/>

                            <Button Content="Export All Summary DOCX"
                                    Command="{Binding ExportAllAiSummaryDocxCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Width="190"
                                    Margin="0"/>
                        </WrapPanel>

                        <TextBox Grid.Row="4"
                                 Text="{Binding AiSummaryPreview, Mode=OneWay}"
                                 Style="{StaticResource ReadOnlyTextBoxStyle}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}" Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>