<Window x:Class="DocForge.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding PreviewTitle}"
        Height="900"
        Width="1200"
        MinHeight="760"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="2.4*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="DocForge"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Text="Extract text from PDF files, reconstruct paragraphs, export to TXT or DOCX, and generate a local AI summary."
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="12,8">
                <TextBlock Text="{Binding IsBusy, StringFormat=Working: {0}}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Selected PDF"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,10"/>

                <TextBlock Text="{Binding SelectedFileName}"
                           Margin="0,0,0,8"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBox Text="{Binding SelectedFilePath}"
                         Style="{StaticResource ReadOnlyTextBoxStyle}"
                         IsReadOnly="True"
                         Margin="0,0,0,12"/>

                <WrapPanel>
                    <Button Content="Browse PDF"
                            Command="{Binding BrowsePdfCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="130"/>

                    <Button Content="Extract Text"
                            Command="{Binding ExtractTextCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="130"/>

                    <Button Content="Export TXT"
                            Command="{Binding ExportTxtCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="130"/>

                    <Button Content="Export DOCX"
                            Command="{Binding ExportDocxCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="130"
                            Margin="0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Extracted Text Preview"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding ExtractedLineCount, StringFormat=Lines: {0}}"
                                   Margin="0,0,12,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>

                        <TextBlock Text="{Binding ExtractedCharacterCount, StringFormat=Characters: {0}}"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="2">
                    <TextBox Text="{Binding ExtractedText}"
                             Style="{StaticResource ReadOnlyTextBoxStyle}"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             IsReadOnly="True"/>

                    <TextBlock Text="{Binding PreviewPlaceholder}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasExtractedText}" Value="False">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <TextBlock Grid.Row="4"
                           Text="The preview reflects the extracted embedded text from the selected PDF."
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Grid>
        </Border>

        <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="AI Summary"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <StackPanel Grid.Row="2">
                    <TextBlock Text="{Binding AiSummaryStatus}"
                               Margin="0,0,0,10"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <WrapPanel Margin="0,0,0,10">
                        <Button Content="Generate AI Summary"
                                Command="{Binding GenerateAiSummaryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="170"
                                IsEnabled="{Binding IsAiSummaryAvailable}" />

                        <Button Content="Export Summary TXT"
                                Command="{Binding ExportAiSummaryTxtCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="165" />

                        <Button Content="Export Summary DOCX"
                                Command="{Binding ExportAiSummaryDocxCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Width="175"
                                Margin="0" />
                    </WrapPanel>
                </StackPanel>

                <TextBox Grid.Row="4"
                         Text="{Binding AiSummaryResult}"
                         Style="{StaticResource ReadOnlyTextBoxStyle}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         IsReadOnly="True"/>
            </Grid>
        </Border>

        <Border Grid.Row="8" Style="{StaticResource CardBorderStyle}" Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>