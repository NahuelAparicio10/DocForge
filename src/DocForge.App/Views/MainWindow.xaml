<Window x:Class="DocForge.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DocForge"
        Height="760"
        Width="1200"
        MinHeight="650"
        MinWidth="950"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="DocForge"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBlock Text="Extract text from PDF files and export it to TXT or DOCX."
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}"
                    Padding="12,8">
                <TextBlock Text="{Binding IsBusy, StringFormat=Working: {0}}"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Text="Selected PDF"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           Margin="0,0,0,10"/>

                <TextBox Text="{Binding SelectedFilePath}"
                         Style="{StaticResource ReadOnlyTextBoxStyle}"
                         IsReadOnly="True"
                         Margin="0,0,0,12"/>

                <WrapPanel>
                    <Button Content="Browse PDF"
                            Command="{Binding BrowsePdfCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="130"/>

                    <Button Content="Extract Text"
                            Command="{Binding ExtractTextCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="130"/>

                    <Button Content="Export TXT"
                            Command="{Binding ExportTxtCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="130"/>

                    <Button Content="Export DOCX"
                            Command="{Binding ExportDocxCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="130"
                            Margin="0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource CardBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Extracted Text Preview"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>

                <TextBox Grid.Row="2"
                         Text="{Binding ExtractedText}"
                         Style="{StaticResource ReadOnlyTextBoxStyle}"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="Wrap"
                         IsReadOnly="True"/>
            </Grid>
        </Border>

        <Border Grid.Row="6" Style="{StaticResource CardBorderStyle}" Padding="12,10">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"/>
        </Border>
    </Grid>
</Window>